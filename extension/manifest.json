{
  "manifest_version": 3,
  "name": "SteamCMD Workshop Downloader",
  "version": "1.0",
  "description": "Queue Steam Workshop items and download them via your local Python server.",
  "host_permissions": [
    "http://127.0.0.1:5000/*"
  ],
  "permissions": ["downloads"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Workshop Download Queue"
  },
  "content_scripts": [
    {
      "matches": [
        "*://steamcommunity.com/sharedfiles/filedetails/*",
        "*://steamcommunity.com/workshop/filedetails/*",
        "*://steamcommunity.com/workshop/browse/*",
        "*://steamcommunity.com/app/*/workshop/*"
      ],
      "js": ["content.js"]
    }
  ]
}